const getInitialTheme = () => {
  const saved = localStorage.getItem('sv_dark');
  if (saved !== null) return saved !== 'false';

  const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
  if (prefersDark) return true;

  const hour = new Date().getHours();
  return hour >= 19 || hour < 7;
};

// Rendert <picture> mit AVIF → WebP → JPG Fallback für lokale Dateien.
// Externe URLs (http/https) werden direkt als <img> ausgegeben.
function Bild({ src, alt, style }) {
  if (!src || /^https?:\/\//.test(src)) {
    return <img src={src} alt={alt} style={style} />;
  }
  const basis = src.replace(/\.(jpg|jpeg)$/i, '');
  return (
    <picture style={{ display: 'contents' }}>
      <source srcSet={`${basis}.avif`} type="image/avif" />
      <source srcSet={`${basis}.webp`} type="image/webp" />
      <img src={src} alt={alt} style={style} />
    </picture>
  );
}

