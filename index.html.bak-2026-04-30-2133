          </p>
          <p style={{ fontSize:16, lineHeight:1.8, color:th.textMuted, marginBottom:24 }}>
            What I keep coming back to is everyday photography. Unplanned moments, real situations. Nothing staged. It’s probably the hardest kind, which is partly why I like it. I don’t see myself as the most talented, but I truly enjoy what I do.
          </p>
          <p style={{ fontSize:16, lineHeight:1.8, color:th.textMuted, marginBottom:24 }}>
            If someone looks at a photo of mine and actually feels something, that’s honestly the best part.
          </p>
          <p style={{ fontSize:16, lineHeight:1.8, color:th.textSub }}>
            When I’m not shooting, I travel, spend time outside, and try to be present with my family. That’s also, not coincidentally, what tends to end up in my pictures.
          </p>
        </div>
        <div>
          <img src="images/about-sven.jpg"
            alt="Portrait of Sven Belz" style={{ width:'100%', display:'block' }}/>
        </div>
      </div>
    </div>
  );
}

function LegalPage({ title, content, th, isMobile }) {
  return (
    <div style={{ padding:isMobile ? '48px 24px 72px' : '80px 60px 120px', maxWidth:700 }}>
      <h2 style={{ fontFamily:'Barlow Condensed', fontWeight:900,
        fontSize:'clamp(36px, 5vw, 72px)', textTransform:'uppercase',
        letterSpacing:'0.02em', marginBottom:48, color:th.text }}>{title}</h2>
      <div style={{ fontSize:15, lineHeight:1.9, color:th.textMuted }}
        dangerouslySetInnerHTML={{ __html: content }}/>
    </div>
  );
}

// ── APP ───────────────────────────────────────────────────────────────────────
function App() {
  const [page, setPage]         = useState(() => localStorage.getItem('sv_page') || 'home');
  const [dark, setDark]         = useState(getInitialTheme);
  const [gallery, setGallery]   = useState(null);
  const [menuOpen, setMenuOpen] = useState(false);
  const [isMobile, setIsMobile] = useState(() => window.innerWidth <= 768);
  const th = dark ? THEMES.dark : THEMES.light;

  useEffect(() => { localStorage.setItem('sv_page', page); }, [page]);
  useEffect(() => {
    localStorage.setItem('sv_dark', dark);
    document.body.style.background = th.bg;
    document.body.style.color = th.text;
  }, [dark, th]);

  useEffect(() => {
    const onResize = () => setIsMobile(window.innerWidth <= 768);
    window.addEventListener('resize', onResize);
    return () => window.removeEventListener('resize', onResize);
  }, []);

  useEffect(() => {
    if (localStorage.getItem('sv_dark') !== null || !window.matchMedia) return;
    const media = window.matchMedia('(prefers-color-scheme: dark)');
    const applyAutoTheme = e => setDark(e.matches);
    if (media.addEventListener) media.addEventListener('change', applyAutoTheme);
    else if (media.addListener) media.addListener(applyAutoTheme);
    return () => {
      if (media.removeEventListener) media.removeEventListener('change', applyAutoTheme);
      else if (media.removeListener) media.removeListener(applyAutoTheme);
    };
  }, []);

  const navigate = p => { setPage(p); setMenuOpen(false); window.scrollTo(0, 0); };

  const renderPage = () => {
    switch(page) {
      case 'home':        return <HomePage onOpen={setGallery} th={th} isMobile={isMobile} />;
      case 'street':      return <GridPage title="Street" projects={PROJECTS.street} onOpen={setGallery} th={th} isMobile={isMobile} />;
      case 'travel':      return <GridPage title="Travel" projects={PROJECTS.travel} onOpen={setGallery} th={th} isMobile={isMobile} />;
      case 'about':       return <AboutPage th={th} isMobile={isMobile} />;
      case 'impressum':   return <LegalPage title="Impressum" th={th} isMobile={isMobile} content={`
        <p style="margin-bottom:16px"><strong>Verantwortlich für den Inhalt:</strong></p>
        <p style="margin-bottom:8px">Sven Belz<br/>Musterstraße 42<br/>10115 Berlin</p>
        <p style="margin-top:16px;margin-bottom:16px">kontakt@svenbelz.de</p>
        <p>Alle Bilder und Inhalte auf dieser Website sind urheberrechtlich geschützt.</p>
      `}/>;
      case 'datenschutz': return <LegalPage title="Datenschutz" th={th} isMobile={isMobile} content={`
        <p style="margin-bottom:16px">Diese Website erhebt keine personenbezogenen Daten und verwendet keine Cookies.</p>
        <p style="margin-bottom:16px"><strong>Hosting</strong><br/>Beim Besuch werden durch den Hosting-Anbieter Server-Logs gespeichert (IP-Adresse, Zeitstempel, aufgerufene Seite).</p>
        <p><strong>Kontakt</strong><br/>kontakt@svenbelz.de</p>
      `}/>;
      default: return <HomePage onOpen={setGallery} th={th} />;
    }
  };

  return (
    <div style={{ minHeight:'100vh', display:'flex', flexDirection:'column',
      background:th.bg, transition:'background 0.4s' }}>
      <style>{`
        @keyframes fadeIn    { from { opacity:0 } to { opacity:1 } }
        @keyframes slideDown { from { opacity:0; transform:translateY(-6px) } to { opacity:1; transform:translateY(0) } }
      `}</style>

      {/* NAV */}
      <nav style={{ position:'sticky', top:0, zIndex:500,
        display:'flex', alignItems:'center', justifyContent:'space-between',
        padding:isMobile ? '0 18px' : '0 40px', height:64,
        background:th.bgNav, backdropFilter:'blur(12px)',
        borderBottom:`1px solid ${th.border}`,
        transition:'background 0.4s, border-color 0.4s' }}>

        <div className="nav-desktop" style={{ display:'flex', gap:0 }}>
          {NAV.map(n => (
            <button key={n.id} onClick={() => navigate(n.id)} style={{
              background:'none', border:'none', cursor:'pointer',
              color: page===n.id ? th.text : th.textMuted,
              fontFamily:'Barlow Condensed', fontWeight:900, fontSize:15,
              letterSpacing:'0.12em', textTransform:'uppercase',
              padding:'0 18px', height:64,
              borderBottom: page===n.id ? `2px solid ${th.text}` : '2px solid transparent',
              transition:'color 0.2s, border-color 0.2s',
            }}>{n.label}</button>
          ))}
        </div>

        <div style={{ display:'flex', alignItems:'center', gap:8 }}>
          <button onClick={() => setDark(d => !d)}
            title={dark ? 'Hellmodus' : 'Dunkelmodus'}
            aria-label={dark ? 'Zu Hellmodus wechseln' : 'Zu Dunkelmodus wechseln'}
            style={{ background:'transparent', border:'none', cursor:'pointer',
              width:40, height:40, display:'flex', alignItems:'center', justifyContent:'center',
              color:th.text, transition:'color 0.3s' }}>
            {dark ? (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="12" cy="12" r="4" stroke={th.text} strokeWidth="1.8"/>
                <path d="M12 2.5V5.2M12 18.8V21.5M21.5 12H18.8M5.2 12H2.5M18.72 5.28L16.81 7.19M7.19 16.81L5.28 18.72M18.72 18.72L16.81 16.81M7.19 7.19L5.28 5.28" stroke={th.text} strokeWidth="1.8" strokeLinecap="round"/>
              </svg>
            ) : (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M20.2 14.1A8.5 8.5 0 1 1 9.9 3.8a7 7 0 1 0 10.3 10.3Z" stroke={th.text} strokeWidth="1.8" strokeLinecap="round" strokeLinejoin="round"/>
              </svg>
            )}
          </button>
          <button onClick={() => setMenuOpen(m => !m)} className="nav-burger"
            style={{ display:'none', background:'none', border:'none', cursor:'pointer',
              width:40, height:40, flexDirection:'column', alignItems:'center',
              justifyContent:'center', gap:5, padding:0 }}>
            {menuOpen
              ? <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                  <line x1="1" y1="1" x2="17" y2="17" stroke={th.text} strokeWidth="1.8"/>
                  <line x1="17" y1="1" x2="1" y2="17" stroke={th.text} strokeWidth="1.8"/>
                </svg>
              : <>
                  <span style={{ display:'block', width:22, height:1.5, background:th.text }}/>
                  <span style={{ display:'block', width:22, height:1.5, background:th.text }}/>
                  <span style={{ display:'block', width:22, height:1.5, background:th.text }}/>
                </>
            }
          </button>
        </div>
      </nav>

      {menuOpen && (
        <div className="nav-mobile-menu" style={{ display:'none',
          position:'fixed', top:64, left:0, right:0, zIndex:499,
          background:th.bgNav, backdropFilter:'blur(16px)',
          borderBottom:`1px solid ${th.border}`,
          animation:'slideDown 0.25s ease' }}>
          {NAV.map(n => (
            <button key={n.id} onClick={() => navigate(n.id)} style={{
              display:'block', width:'100%', background:'none', border:'none',
              borderBottom:`1px solid ${th.border}`,
              cursor:'pointer', textAlign:'left', padding:isMobile ? '18px 24px' : '18px 40px',
              fontFamily:'Barlow Condensed', fontWeight:900, fontSize:22,
              letterSpacing:'0.1em', textTransform:'uppercase',
              color: page===n.id ? th.text : th.textMuted,
              transition:'color 0.2s',
            }}>{n.label}</button>
          ))}
        </div>
      )}

      <main style={{ flex:1, animation:'slideDown 0.3s ease' }} key={page}>
        {renderPage()}
      </main>

      <footer style={{ borderTop:`1px solid ${th.border}`, padding:isMobile ? '24px' : '32px 60px',
        display:'flex', justifyContent:'space-between', alignItems:'center',
        flexWrap:'wrap', gap:16, transition:'border-color 0.4s' }}>
        <span style={{ fontFamily:'Barlow Condensed', fontWeight:700, fontSize:14,
          color:th.textSub, letterSpacing:'0.06em', textTransform:'uppercase' }}>
          &copy; {new Date().getFullYear()} Sven Belz
        </span>
        <div style={{ display:'flex', gap:32 }}>
          {[['impressum','Impressum'],['datenschutz','Datenschutz']].map(([id, label]) => (
            <button key={id} onClick={() => navigate(id)} style={{
              background:'none', border:'none', cursor:'pointer',
              color: th.textMuted,
              fontFamily:'Barlow Condensed', fontSize:13, fontWeight:600,
              letterSpacing:'0.08em', textTransform:'uppercase', transition:'color 0.2s',
            }}>{label}</button>
          ))}
        </div>
      </footer>

      {gallery && <Gallery project={gallery} onClose={() => setGallery(null)} th={th} isMobile={isMobile} />}
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App />);
</script>
</body>
</html>
